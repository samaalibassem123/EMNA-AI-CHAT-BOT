# SQL Server connection
DB_USER=your_username
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=1433
DB_NAME=mydatabase
DB_DRIVER=ODBC+Driver+18+for+SQL+Server
# SQLAlchemy async URL
DATABASE_URL=mssql+aioodbc://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?driver=${DB_DRIVER}


  
#Ollama for cloud service
OLLAMA_API_KEY=
# GOOGLE Ai key
GOOGLE_AI_KEY=